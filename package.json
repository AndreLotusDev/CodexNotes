{
  "name": "tinynotes",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.13",
  "scripts": {
    "dev": "bun run --bun next dev",
    "build": "bun run --bun next build",
    "start": "bun run --bun next start",
    "lint": "bun run --bun next lint",
    "typecheck": "bun run --bun tsc --noEmit",
    "migrate": "bun run ./scripts/migrate.ts",
    "migrate:down": "bun run ./scripts/migrate-down.ts",
    "test:browser": "bunx playwright test -c browser-tests/playwright.config.ts",
    "test:browser:headed": "bunx playwright test -c browser-tests/playwright.config.ts --headed",
    "test:browser:ui": "bunx playwright test -c browser-tests/playwright.config.ts --ui",
    "test:browser:install": "bunx playwright install chromium"
  },
  "dependencies": {
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "better-auth": "^1.6.9",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.5",
    "@types/node": "^22.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.1.5",
    "typescript": "^5.8.3"
  }
}
